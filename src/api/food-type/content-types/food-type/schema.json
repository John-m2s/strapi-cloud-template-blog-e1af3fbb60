    },
    "displayTitle": {
      "type": "string"
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "files",
        "images"
      ]
    },
    "heroImg": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "order": {
      "type": "integer"
    },
    "shortDesc": {
      "type": "richtext"
    },
    "htmlContent": {
      "type": "richtext"
    }
  }
