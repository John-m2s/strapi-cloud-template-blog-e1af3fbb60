{
  "kind": "collectionType",
  "collectionName": "cms_articles",
  "info": {
    "singularName": "cms-article",
    "pluralName": "cms-articles",
    "displayName": "CMS Article"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "content": {
      "type": "richtext"
    },
    "source": {
      "type": "string"
    },
    "sourceUrl": {
      "type": "string"
    },
    "cms_category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::cate.cate",
      "inversedBy": "cms_articles"
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    }
  }
}
